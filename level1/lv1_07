# Tự định nghĩa hàm và thêm tài liệu:
def tinh_dien_tich_hinh_chu_nhat(dai, rong):
    """Hàm này dùng để tính diện tích hình chữ nhật

    Tham số:
    dai (float/int): Chiều dài của hình chữ nhật
    rong (float/int): Chiều rộng của hình chữ nhật

    Trả về:
    float/int: Diện tích của hình chữ nhật
    """
    return dai * rong
print("Tài liệu hàm tự định nghĩa")
print(tinh_dien_tich_hinh_chu_nhat.__doc__)